# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=smart_desk_assistant

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:19006,exp://192.168.1.100:19000

# Protonest Connect Configuration
PROTONEST_API_URL=https://api.protonestconnect.co/api/v1/user
PROTONEST_ENCRYPTION_KEY=change_this_to_a_random_32_char_string

# AI Provider for smart insights (gemini or openai)
AI_PROVIDER=gemini
AI_API_KEY=your_api_key_here
AI_INSIGHT_INTERVAL_HOURS=2

# Topic Mapping: protonest_topic_suffix:db_column
TOPIC_MAPPING=gas:air_quality,light:light_level,noise:noise_level,temperature:temperature,humidity:humidity
